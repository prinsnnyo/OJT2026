{
  "name": "ojt-todo-app",
  "version": "1.0.0",
  "private": true,
  "description": "OJT Todo App — Nuxt frontend + NestJS backend + PostgreSQL",
  "scripts": {
    "install:all": "npm install --prefix frontend && npm install --prefix backend",
    "dev:backend": "npm run start:dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "build:backend": "npm run build --prefix backend",
    "build:frontend": "npm run build --prefix frontend",
    "db:generate": "npm run db:generate --prefix backend",
    "db:migrate": "npm run db:migrate --prefix backend",
    "db:seed": "npm run db:seed --prefix backend",
    "db:studio": "npm run db:studio --prefix backend",
    "prepare:frontend": "npm run postinstall --prefix frontend"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
